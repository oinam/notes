{
  "$schema": "https://ovellum.oss.oinam.com/schema/ovellum.config.schema.json",
  "name": "oinam-notes",
  "mode": "manual",
  "input": ".",
  "output": "dist",
  "site": {
    "title": "Oinam Notes",
    "description": "An ever work-in-progress of tit-bits, wiki-ish, data, learnings, and observations by Oinam.",
    "baseUrl": "https://notes.oinam.com",
    "search": { "enabled": true },
    "ignoreFolders": ["node_modules", "dist", ".git", ".github", ".claude", ".obsidian"],
    "defaultTheme": "auto",
    "palette": "eink",
    "favicon": "/favicon.ico",
    "logo": "/oinam-logo.svg",
    "footer": "Since 2003 — Oinam",
    "footerNav": [
      { "label": "GitHub", "href": "https://github.com/oinam", "external": true },
      { "label": "X", "href": "https://x.com/oinam", "external": true },
      { "label": "Instagram", "href": "https://instagram.com/oinam", "external": true }
    ]
  }
}
